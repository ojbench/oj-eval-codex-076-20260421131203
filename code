// MyList template implementation per assignment
// Implemented using std::vector for performance and simplicity.
#include <vector>
#include <cstddef>

template<typename ValueType>
class MyList {
    std::vector<ValueType> data_;
public:
    MyList() = default;
    MyList(MyList &&obj) noexcept : data_(std::move(obj.data_)) {}
    MyList(const MyList &obj) : data_(obj.data_) {}
    MyList& operator=(const MyList& other) { data_ = other.data_; return *this; }
    MyList& operator=(MyList&& other) noexcept { data_ = std::move(other.data_); return *this; }
    ~MyList() = default;

    void push_back(const ValueType &value) { data_.push_back(value); }
    void pop_back() { if (!data_.empty()) data_.pop_back(); }
    void push_front(const ValueType &value) { data_.insert(data_.begin(), value); }
    void pop_front() { if (!data_.empty()) data_.erase(data_.begin()); }
    ValueType &front() const { return const_cast<ValueType&>(data_.front()); }
    ValueType &back() const { return const_cast<ValueType&>(data_.back()); }

    void insert(int index,const ValueType &value) {
        if (index <= 0) { data_.insert(data_.begin(), value); return; }
        if (index >= (int)data_.size()) { data_.push_back(value); return; }
        data_.insert(data_.begin() + index, value);
    }
    void erase(int index) {
        if (index < 0 || index >= (int)data_.size()) return;
        data_.erase(data_.begin() + index);
    }
    int size() const { return (int)data_.size(); }
    bool empty() const { return data_.empty(); }
    void clear() { data_.clear(); }

    void link(const MyList &obj) {
        data_.reserve(data_.size() + obj.data_.size());
        data_.insert(data_.end(), obj.data_.begin(), obj.data_.end());
    }
    MyList cut(int index) {
        MyList ret;
        if (index <= 0) {
            ret.data_ = std::move(data_);
            return ret;
        }
        if (index >= (int)data_.size()) {
            return ret;
        }
        ret.data_.assign(data_.begin() + index, data_.end());
        data_.erase(data_.begin() + index, data_.end());
        return ret;
    }
};
